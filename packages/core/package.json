{
  "name": "@droidproxy/core",
  "version": "0.1.0",
  "private": true,
  "description": "Shared constants and core modules for DroidProxy",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
