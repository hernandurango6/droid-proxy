{
  "name": "@droidproxy/management-client",
  "version": "0.1.0",
  "private": true,
  "description": "Typed HTTP client for cli-proxy-api /v0/management",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "node --import tsx --test src/__tests__/index.test.ts src/__tests__/client.test.ts src/__tests__/auth-files.test.ts src/__tests__/api-call.test.ts src/__tests__/version.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@droidproxy/core": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}