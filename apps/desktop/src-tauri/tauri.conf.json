{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DroidProxy",
  "version": "0.1.0",
  "identifier": "com.droidproxy.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../.. sidecar:build && pnpm --dir ../.. --filter @droidproxy/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DroidProxy",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../../../resources/bin/cli-proxy-api.exe": "bin/cli-proxy-api.exe",
      "../../../apps/sidecar/dist/droidproxy-sidecar.exe": "bin/droidproxy-sidecar.exe",
      "../../../resources/config.template.yaml": "config.template.yaml"
    }
  }
}